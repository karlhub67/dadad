local function StartMainScript()
    _G.KarlhubV3 = true 
    loadstring(game:HttpGet(mainScriptURL))()
end

local function CreateGUI()
    local target = game:GetService("CoreGui")
    if target:FindFirstChild("OYB_KeySystem") then target.OYB_KeySystem:Destroy() end

    local sg = Instance.new("ScreenGui", target); sg.Name = "OYB_KeySystem"
    
    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0, 320, 0, 240)
    main.Position = UDim2.new(0.5, -160, 0.5, -120)
    main.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
    main.BorderSizePixel = 0
    main.Active = true; main.Draggable = true
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)

    local grad = Instance.new("UIGradient", main)
    grad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(15, 15, 15)), ColorSequenceKeypoint.new(1, Color3.fromRGB(25, 25, 25))}

    local Title = Instance.new("TextLabel", main)
    Title.Size = UDim2.new(1, 0, 0, 45)
    Title.Text = "KarlHub"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.GothamBold; Title.TextSize = 18; Title.BackgroundTransparency = 1

    local Input = Instance.new("TextBox", main)
    Input.Size = UDim2.new(0.8, 0, 0, 40)
    Input.Position = UDim2.new(0.1, 0, 0.3, 0)
    Input.PlaceholderText = "Paste key here..."
    Input.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Input.TextColor3 = Color3.new(1, 1, 1); Input.Font = "Gotham"; Input.TextSize = 14
    Instance.new("UICorner", Input)

    local Verify = Instance.new("TextButton", main)
    Verify.Size = UDim2.new(0.38, 0, 0, 40)
    Verify.Position = UDim2.new(0.1, 0, 0.55, 0)
    Verify.Text = "VERIFY"
    Verify.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    Verify.TextColor3 = Color3.new(1, 1, 1); Verify.Font = "GothamBold"
    Instance.new("UICorner", Verify)

    local GetK = Instance.new("TextButton", main)
    GetK.Size = UDim2.new(0.38, 0, 0, 40)
    GetK.Position = UDim2.new(0.52, 0, 0.55, 0)
    GetK.Text = "GET KEY"
    GetK.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    GetK.TextColor3 = Color3.new(1, 1, 1); GetK.Font = "GothamBold"
    Instance.new("UICorner", GetK)

    local Status = Instance.new("TextLabel", main)
    Status.Size = UDim2.new(1, 0, 0, 30)
    Status.Position = UDim2.new(0, 0, 0.82, 0)
    Status.Text = "Awaiting Activation..."
    Status.TextColor3 = Color3.fromRGB(100, 100, 100)
    Status.Font = "Gotham"; Status.TextSize = 12; Status.BackgroundTransparency = 1

    Verify.MouseButton1Click:Connect(function()
        if Input.Text == "" then Status.Text = "Missing Key!"; return end
        Status.Text = "Checking..."
        local ok, err = redeemKey(Input.Text)
        if ok then
            Status.Text = "Authorized! Enjoy."; Status.TextColor3 = Color3.fromRGB(0, 255, 120)
            task.wait(1); sg:Destroy(); StartMainScript()
        else
            Status.Text = err; Status.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
    end)

    GetK.MouseButton1Click:Connect(function()
        Status.Text = "Copying Link..."
        local ok, link = cacheLink()
        if ok then fSetClipboard(link); Status.Text = "Link Copied to Clipboard!"
        else Status.Text = "Link Error!" end
    end)
end

CreateGUI()
