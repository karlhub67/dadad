local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local player = Players.LocalPlayer

local AutoGetPlants = false
local connection

local FAR_DISTANCE = 400
local NEAR_DISTANCE = 16
local CurrentDistance = NEAR_DISTANCE

local prompts = {}

local function getRoot()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- Store prompts
for _, v in ipairs(Workspace:GetDescendants()) do
    if v:IsA("ProximityPrompt") then
        table.insert(prompts, v)
    end
end

Workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("ProximityPrompt") then
        table.insert(prompts, obj)
    end
end)

local function startLoop()
    if connection then return end

    connection = RunService.Heartbeat:Connect(function()
        if not AutoGetPlants then return end

        local root = getRoot()
        if not root then return end

        for i = #prompts, 1, -1 do
            local prompt = prompts[i]
            local parent = prompt and prompt.Parent

            if not prompt or not parent then
                table.remove(prompts, i)
            else
                -- Find a BasePart to measure from
                local part = parent:IsA("BasePart") and parent
                    or parent:FindFirstChildWhichIsA("BasePart")

                if not part then
                    table.remove(prompts, i)
                else
                    local dist = (part.Position - root.Position).Magnitude

                    if dist <= CurrentDistance then
                        prompt:InputHoldBegin()
                        prompt:InputHoldEnd()
                    end
                end
            end
        end
    end)
end

local function stopLoop()
    if connection then
        connection:Disconnect()
        connection = nil
    end
end

